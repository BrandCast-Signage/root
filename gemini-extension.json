{
  "name": "root",
  "description": "Development workflow framework — tier-based planning, doc-aware context gathering, RAG-powered search, session tracking, and implementation plan generation",
  "version": "1.5.3",
  "commands": "commands/**/*.toml",
  "hooks": "hooks/gemini-hooks.json",
  "skills": [
    "skills/*/SKILL.md"
  ],
  "agents": [
    "agents/*.md"
  ],
  "mcpServers": {
    "local-rag": {
      "command": "node",
      "args": [
        "${HOME}/.root-framework/mcp/node_modules/mcp-local-rag/dist/index.js"
      ],
      "env": {
        "DB_PATH": ".root/rag-db",
        "CACHE_DIR": "${HOME}/.cache/mcp-local-rag/models"
      }
    }
  }
}
