{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${GEMINI_EXTENSION_DIR}/hooks/scripts/ensure-rag.sh",
            "timeout": 300
          }
        ]
      }
    ],
    "AfterTool": [
      {
        "matcher": "replace|write_file",
        "hooks": [
          {
            "type": "command",
            "command": "${GEMINI_EXTENSION_DIR}/hooks/scripts/track-edits.sh"
          }
        ]
      },
      {
        "matcher": "read_file|grep_search",
        "hooks": [
          {
            "type": "command",
            "command": "${GEMINI_EXTENSION_DIR}/hooks/scripts/track-doc-reads.sh"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${GEMINI_EXTENSION_DIR}/hooks/scripts/context-receipt.sh"
          },
          {
            "type": "command",
            "command": "${GEMINI_EXTENSION_DIR}/hooks/scripts/doc-update-check.sh"
          }
        ]
      }
    ]
  }
}
