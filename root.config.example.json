{
  "configVersion": 2,
  "board": {
    "gates": {
      "plan_approval": { "tier1": "human", "tier2": "auto" },
      "reviewer_pass": "auto",
      "validation": "auto",
      "pr_creation": "auto"
    },
    "maxParallel": 3,
    "githubProject": {
      "_comment": "Optional. When present, board_start sets the linked Project v2 item's Status to In Progress and applies mirrorLabel. If startDateFieldId is set, board_start also writes today's date to that Date field on first run (first-write-wins) — enables velocity charts (start_date → close_date). Look up node IDs once via `gh api graphql` (see README → GitHub Project sync).",
      "projectId": "PVT_xxxxxxxxxxxxxxxxx",
      "statusFieldId": "PVTSSF_xxxxxxxxxxxxxxxxx",
      "statusOptions": {
        "inProgress": "xxxxxxxx"
      },
      "mirrorLabel": "status:in-progress",
      "startDateFieldId": "PVTF_xxxxxxxxxxxxxxxxx"
    }
  },
  "project": {
    "name": "my-project",
    "docsDir": "docs",
    "plansDir": "docs/plans",
    "prdsDir": "docs/prds"
  },
  "ingest": {
    "dbPath": ".root/rag-db",
    "docs": ["docs/"]
  },
  "docMappings": [
    { "pattern": "AUTH|OAUTH|SESSION", "agents": ["specialist-backend"], "skills": [] },
    { "pattern": "DATABASE|SCHEMA|MIGRATION", "agents": ["specialist-database"], "skills": [] },
    { "pattern": "DEPLOY|K8S|DOCKER|PIPELINE|CI", "agents": ["specialist-devops"], "skills": [] },
    { "pattern": "UI|UX|COMPONENT|DESIGN", "agents": ["specialist-frontend"], "skills": [] }
  ],
  "labelMappings": [
    { "label": "area:frontend", "agents": ["specialist-frontend"] },
    { "label": "area:backend", "agents": ["specialist-backend"] },
    { "label": "area:database", "agents": ["specialist-database"] },
    { "label": "area:infrastructure", "agents": ["specialist-devops"] }
  ],
  "keywordMappings": [
    { "keywords": ["schema", "migration", "database", "prisma"], "agents": ["specialist-database"] },
    { "keywords": ["deploy", "pipeline", "k8s", "docker", "CI", "infrastructure"], "agents": ["specialist-devops"] },
    { "keywords": ["test", "coverage", "vitest", "jest"], "agents": ["team-tester"] },
    { "keywords": ["component", "UI", "UX", "frontend", "react"], "agents": ["specialist-frontend"] }
  ],
  "docTargets": [
    { "glob": "packages/*/src/index.ts", "type": "package", "docsDir": "docs/packages" },
    { "glob": "apps/*/src/services/*.ts", "type": "service", "docsDir": "docs/services" },
    { "glob": "apps/*/src/routes/*.ts", "type": "api", "docsDir": "docs/api" }
  ],
  "codingStandards": [
    "All new exports have JSDoc with @param, @returns, @throws",
    "No `any` types — use generics or narrowed unions",
    "No `console.log` in production code — use structured logger"
  ],
  "validation": {
    "lintCommand": "npm run lint && npm run type-check",
    "testCommand": "npm test -- <pattern>"
  },
  "notifications": {
    "_comment": "Optional. Discord webhook for autonomous-mode signaling. Webhook URL is read from the ROOT_DISCORD_WEBHOOK_URL environment variable — never store it here. Section absent or `enabled: false` = feature off.",
    "discord": {
      "enabled": true,
      "events": ["blocker", "human_gate", "pr_ready", "epic_complete"],
      "mention": null
    }
  }
}
